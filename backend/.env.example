# ── LLM Providers ──────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ── Agent LLM routing (groq | ollama) ─────────────────────────
ORCHESTRATOR_PROVIDER=groq
EXECUTOR_PROVIDER=ollama
CRITIC_PROVIDER=ollama
EXECUTOR_MAX_TURNS=5

# ── Embeddings ─────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ── Paths ──────────────────────────────────────────────────────
LOG_DIR=logs

# ── Agent behaviour ────────────────────────────────────────────
MAX_RETRIES=3
ANOMALY_DRIFT_THRESHOLD=0.45

# ── Critic v3: factual grounding (hallucination detection) ─────
GROUNDING_ENABLED=true

# ── Optional: HuggingFace token (GAIA benchmark download) ──────
HUGGING_FACE_TOKEN=
